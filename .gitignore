# ======================================
# PROTECTION DU CODE SOURCE
# Ne pas pousser le code sur GitHub
# ======================================

# Exclure TOUT le code source Dart/Flutter
lib/
test/

# Exclure les fichiers de configuration sensibles
pubspec.lock
android/
ios/
linux/
macos/
windows/
web/

# Exclure les dépendances et caches
.flutter-plugins
.packages
.metadata

# Garder UNIQUEMENT (non-ignorés) :
# - README.md
# - assets/ (logo, images publiques)
# - .gitignore
# - pubspec.yaml (optionnel, contient la liste des dépendances)

